# Copy this file to ".env" in the repo root and fill in secrets.
# Or pass --dotenv /path/to/.env when running sim_eval.py or sim_vlm_to_actions_eval.py.
# load_env() does not override variables already set in your shell.

# -----------------------------------------------------------------------------
# OpenAI-compatible VLM (vlm_to_actions.py — used by sim_eval --from-vlm-text, sim_vlm_to_actions_eval, etc.)
# -----------------------------------------------------------------------------
# Required for API calls:
OPENAI_API_KEY=

# Optional: API base (OpenAI official, Azure OpenAI, vLLM, LiteLLM proxy, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: default model when a code path does not pass model= explicitly
# OPENAI_MODEL=gpt-4o-mini

# Optional: override for vision / inventory calls (defaults to OPENAI_MODEL)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Optional: override for text planning calls (defaults to OPENAI_MODEL)
# OPENAI_PLAN_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Hugging Face (optional — if you load policies with --policy-id from the Hub)
# -----------------------------------------------------------------------------
# HF_TOKEN=
