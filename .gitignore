# --- git pull / clone shield: keep local-only files out of the repo ---
# Untracked paths are never merged from upstream; your .env stays local.
.env
.env.*
!.env.example

# Python / tooling
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Local runs / caches
runs/
*.log
